{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR_BACKEND_URL_HERE/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://YOUR_BACKEND_URL_HERE/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
